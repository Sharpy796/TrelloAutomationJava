    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="0px"
        android:layout_weight="1"
        android:gravity="top"
        tools:context=".MainActivity">
        <!-- title row -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Trello Card Creator"
            android:textAlignment="center"
            android:textSize="24dp" />

        <!-- name row -->
        <TextView
            android:id="@+id/namelabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title"
            android:layout_alignParentStart="true"
            android:padding="16dp"
            android:text="Name:" />

        <EditText
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title"
            android:layout_alignStart="@+id/description"
            android:layout_alignTop="@+id/namelabel"
            android:layout_alignBottom="@+id/namelabel"
            android:background="@android:drawable/editbox_background"
            android:elegantTextHeight="true"
            android:hint="Your Task"
            android:padding="16dp"
            android:textColor="@android:color/background_dark"
            android:textColorHint="@color/cardview_shadow_start_color"
            android:textSize="7pt" />

        <!-- desc row -->
        <TextView
            android:id="@+id/descriptionlabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/namelabel"
            android:layout_alignParentStart="true"
            android:padding="16dp"
            android:text="Description:" />

        <EditText
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_below="@+id/namelabel"
            android:layout_alignTop="@+id/descriptionlabel"
            android:layout_toEndOf="@id/descriptionlabel"
            android:background="@android:drawable/editbox_background"
            android:elegantTextHeight="true"
            android:gravity="top"
            android:hint="Task Description"
            android:padding="16dp"
            android:textColor="@android:color/background_dark"
            android:textColorHint="@color/cardview_shadow_start_color"
            android:textSize="7pt" />

        <!-- lists row -->
        <TextView
            android:id="@+id/listslabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/description"
            android:layout_alignStart="@+id/description"
            android:layout_alignParentStart="true"
            android:padding="16dp"
            android:text="List:" />

